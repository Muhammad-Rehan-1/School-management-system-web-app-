# Copy to .env and edit if needed

# Database (required for Render PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@db:5432/school"

# Server
PORT=4000

# File uploads
UPLOAD_DIR=./uploads

# CORS - Frontend URL for production (e.g., your Vercel deployment)
# Example: https://your-app-name.vercel.app
FRONTEND_URL="http://localhost:3000"

# MinIO (optional, for S3-like file storage)
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=school-uploads
